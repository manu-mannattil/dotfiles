# vim: ft=conf fdm=marker et sts=2 sw=2
#
# Note that ~/.cvsignore doesn't allow comments (at least rsync doesn't
# allow it).  Therefore, rather than use this file directly, use:
#
#   grep -v '\(^#\|^$\)' .cvsignore | sort | uniq > ~/.cvsignore
#

