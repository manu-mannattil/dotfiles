# vim: ft=yaml fdm=marker et sts=2 sw=2
Language: Cpp
BasedOnStyle: LLVM
UseTab: Never
IndentWidth: 4
ColumnLimit: 100

# Force pointers to the type, e.g.,
#   int* x;
DerivePointerAlignment: false
PointerAlignment: Left

# If true, a space is inserted after C style casts, e.g.,
#   int x = (int) 3.1415;
#   int* x = (int*) malloc(N * sizeof(int));
SpaceAfterCStyleCast: true

# Don't intend "private:", "public:", etc.
IndentAccessModifiers: false
AccessModifierOffset: -4
EmptyLineAfterAccessModifier: Always
