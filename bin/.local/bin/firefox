#!/bin/sh

profile="default"
case "$1" in
    # If there's a dedicated private profile, prefer that, otherwise,
    # use the incognito mode.
    --private-profile)
        shift
        if grep -q 'Name=private' "$HOME/.config/mozilla/firefox/profiles.ini" >/dev/null 2>&1
        then
            profile="private"
            rm -rf  ~/.cache/mozilla/firefox/*.private                          \
                    ~/.config/mozilla/firefox/*.private/content-prefs.sqlite    \
                    ~/.config/mozilla/firefox/*.private/cookies.sqlite          \
                    ~/.config/mozilla/firefox/*.private/formhistory.sqlite      \
                    ~/.config/mozilla/firefox/*.private/storage.sqlite          \
                    ~/.config/mozilla/firefox/*.private/webappsstore.sqlite     \
                    ~/.config/mozilla/firefox/*.private/crashes                 \
                    ~/.config/mozilla/firefox/*.private/datareporting           \
                    ~/.config/mozilla/firefox/*.private/minidumps               \
                    ~/.config/mozilla/firefox/*.private/storage
        else
            set -- --private-window "$@"
        fi
        ;;
    -*) exec /usr/bin/firefox "$@" ;;
esac

[ "$*" ] || set -- "about:blank"

mkdir -p /tmp/downloads
exec nohup /usr/bin/firefox -P "$profile" "$@" >/dev/null 2>&1 &
