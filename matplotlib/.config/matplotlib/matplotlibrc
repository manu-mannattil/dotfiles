# https://raw.githubusercontent.com/matplotlib/matplotlib/master/matplotlibrc.template

backend: TkAgg

# Default font family and font choices.
font.family: serif
font.serif: Palatino Linotype, serif
mathtext.fontset: custom
mathtext.rm: Palatino Linotype
mathtext.it: Palatino Linotype:italic
mathtext.bf: Palatino Linotype:bold

# Use a larger DPI when saving figures since a lot of people use HiDPI displays
# these days.
savefig.dpi: 300

# Plot style.
figure.figsize: 5.663, 3.5
legend.frameon: False
lines.markerfacecolor: "none"
scatter.edgecolors: "none"
xtick.minor.visible: True
ytick.minor.visible: True
figure.constrained_layout.use: True
